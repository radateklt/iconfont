{
  "name": "@radatek/iconfont",
  "version": "0.1.2",
  "description": "Iconfont vite/tailwind plugins for: Material-Symbols, Fontawesome, Lucide",
  "author": "Radatek, Darius Kisonas",
  "license": "ISC",
  "keywords": [
    "tailwindcss-plugin",
    "vite-plugin",
    "icons",
    "material-icons",
    "material-symbols",
    "fontawesome",
    "lucide"
  ],
  "type": "module",
  "main": "index.js",
  "exports": {
