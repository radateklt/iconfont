    "./tailwind": {
      "types": "./tailwind.d.ts",
      "import": "./tailwind.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/radateklt/iconfont.git"
  },
  "dependencies": {
    "@pixi/svg2ttf": "^6.1.0",
    "fontkit": "^2.0.4",
    "wawoff2": "^2.0.1"
